
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isPublic() {
      return true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin status is determined by the existence of a document in the 'adminUsers' collection
      // with the user's UID as the document ID.
      return exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Allow public read on properties, agents, and blog posts
    match /properties/{propertyId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /estateAgents/{agentId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // `users` collection is for marketing leads. Anyone can create a document.
    // To prevent abuse, further updates could be restricted.
    match /users/{email} {
      allow write: if true;
      allow read: if isSignedIn() && isAdmin(); // Only admins can read the full list
    }

    // adminUsers collection is restricted. Only admins can read it. No one can write to it via client SDK.
    // Admin creation must be done server-side or directly in the Firebase console.
    match /adminUsers/{userId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Anyone can create enquiries or valuation requests.
    match /enquiries/{enquiryId} {
       allow create: if true;
       // Only admins can view/manage them.
       allow read, update, delete: if isSignedIn() && isAdmin();
    }
    
    match /valuationRequests/{requestId} {
       allow create: if true;
       // Only admins can view/manage them.
       allow read, update, delete: if isSignedIn() && isAdmin();
    }
  }
}
