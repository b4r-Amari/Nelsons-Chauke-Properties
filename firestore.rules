
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Publicly readable collections
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    match /agents/{agentId} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    // User data: users can create their own doc and can only read/write their own doc
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Submissions: allow any authenticated user to create.
    match /contactSubmissions/{submissionId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Only admins from server side
    }

    match /enquiries/{enquiryId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Only admins from server side
    }
     match /valuationRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Only admins from server side
    }
  }
}
