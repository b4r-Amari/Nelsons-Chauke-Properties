
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public collections, readable by anyone
    match /properties/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    match /agents/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    match /blogPosts/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Allow writes for authenticated users (admins)
    }

    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Form submissions are write-only for users
    match /contactSubmissions/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Admins can manage
    }

    match /enquiries/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Admins can manage
    }
    
    match /valuationRequests/{documentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Admins can manage
    }
  }
}
