
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isPublic() {
      return true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin status is determined by the existence of a document in the 'admins' collection
      // with the user's UID as the document ID.
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Allow public read on properties, agents, and blog posts
    match /properties/{propertyId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /agents/{agentId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if isPublic();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // Any signed-in user can have a user profile document created for them.
    // Users can only read or update their own profile.
    // Admins can write to any user profile.
    match /users/{userId} {
      allow read, update: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    // Admins collection is restricted. Only admins can read it. No one can write to it via client SDK.
    // Admin creation must be done server-side or directly in the Firebase console.
    match /admins/{userId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Only signed-in users can create enquiries
    match /enquiries/{enquiryId} {
       allow create: if isSignedIn();
       // Only admins can view/manage enquiries
       allow read, update, delete: if isSignedIn() && isAdmin();
    }
  }
}
