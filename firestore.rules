
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isPublic() {
      return true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow public read on properties, agents, and blog posts
    match /properties/{propertyId} {
      allow read: if isPublic();
      allow write: if false; // To be secured later
    }

    match /agents/{agentId} {
      allow read: if isPublic();
      allow write: if false; // To be secured later
    }

    match /blogPosts/{postId} {
      allow read: if isPublic();
      allow write: if false; // To be secured later
    }

    // Users can only manage their own data
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Only signed-in users can create enquiries
    match /enquiries/{enquiryId} {
       allow create: if isSignedIn();
       allow read, update, delete: if false; // To be secured later
    }
  }
}
